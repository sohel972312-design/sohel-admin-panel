# ─── Database (Production) ──────────────────────────────────────────────────
DB_HOST_PROD=localhost
DB_USER_PROD=sohel_admin_user
DB_PASSWORD_PROD=STRONG_DB_PASSWORD_HERE
DB_NAME_PROD=sohel_admin_db
DB_PORT_PROD=3306

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING
JWT_STEP1_SECRET=CHANGE_ME_ANOTHER_64_CHAR_HEX_STRING
INTERNAL_API_KEY=CHANGE_ME_ANOTHER_64_CHAR_HEX_STRING
SESSION_EXPIRES_HOURS=24
SESSION_EXPIRE_MINUTES=30
APP_URL=https://admin.sohelmalek.com

# ─── Email (Gmail SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
ADMIN_EMAIL=your@gmail.com

# ─── Twilio ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+1xxxxxxxxxx

# ─── Image Upload Paths (absolute paths on server) ──────────────────────────
BANNER_UPLOAD_PATH=/var/www/sohel-admin-panel/public/blog-banners/
INNER_IMG_UPLOAD_PATH=/var/www/sohel-admin-panel/public/blog-innerimg/
